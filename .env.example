# === IDENTITY (optional — defaults work for personal use) ===
# AGENT_NAME=TARS
# OPERATOR_NAME=Operator
# VAULT_BASE_PATH=~/agent-data
# CLAUDE_CODE_ALLOWED_PATHS=/path/to/repos/,/path/to/projects/
# PACKAGE_NAME=tars-agent

# Telegram (from BotFather — required)
TELEGRAM_BOT_TOKEN=

# LLM Providers (at least one required, all optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional: Ollama base URL (default: http://127.0.0.1:11434)
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional: restrict to your Telegram user ID(s), comma-separated
TELEGRAM_ALLOWED_USERS=

# Optional: health server port (default: 3210)
# PORT=3210

# Gmail integration (optional)
# 1. Enable Gmail API in GCP console
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: http://localhost:3210/oauth/gmail/callback
# 4. Set client ID + secret below, start the agent, visit http://localhost:3210/oauth/gmail/start
# 5. Authorize, copy refresh token below, restart the agent
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Proactive monitoring (optional)
# Set to the operator's Telegram chat ID to enable inbox monitoring, Docker health alerts,
# and automatic webhook result routing to Telegram.
# Find chat ID: message the bot, then check https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_OWNER_CHAT_ID=

# Webhook secret for POST /webhook/task (used by n8n)
WEBHOOK_SECRET=

# Optional: restrict to Slack user IDs, comma-separated
SLACK_ALLOWED_USERS=

# Miniflux RSS reader (optional)
# Self-hosted Miniflux instance. API key from Miniflux Settings > API Keys.
# MINIFLUX_URL=http://localhost:8080
MINIFLUX_API_KEY=

# n8n workflow automation (optional)
# Self-hosted n8n instance. API key from n8n Settings > API.
# N8N_URL=http://localhost:5678
N8N_API_KEY=

# Claude Code SDK
# ANTHROPIC_API_KEY (above) is also used by the Claude Agent SDK for handoff_to_claude_code.
# No additional keys needed — the SDK reads ANTHROPIC_API_KEY automatically.
